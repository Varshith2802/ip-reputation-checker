{
  "spec": {
    "template": {
      "spec": {
        "containers": [
          {
            "name": "auth-service",
            "readinessProbe": {
              "httpGet": { "path": "/", "port": 8000 },
              "initialDelaySeconds": 2,
              "periodSeconds": 5,
              "timeoutSeconds": 2,
              "failureThreshold": 5
            }
          }
        ]
      }
    }
  }
}
